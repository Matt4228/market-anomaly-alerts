DATABASE_URL=postgresql://postgres:postgres@localhost:5432/market_alerts

TRACKED_TICKERS=AAPL,MSFT,GOOGL,TSLA,SPY
OPENBB_PROVIDER=yfinance

POLL_INTERVAL_MINUTES=5
ALERT_COOLDOWN_MINUTES=30
ANOMALY_ZSCORE_THRESHOLD=3.0
MIN_STDDEV_FRACTION=0.0005

RATE_LIMIT_CAPACITY=5
RATE_LIMIT_REFILL_PER_SEC=1.0
PRICE_CACHE_TTL_SECONDS=60

# Optional — leave blank to skip Slack alerts
SLACK_WEBHOOK_URL=
